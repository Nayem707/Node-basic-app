# ১. অফিশিয়াল Node.js ইমেজ ব্যবহার করছি
FROM node:18-alpine

# ২. কন্টেইনারের ভেতরে কাজের ফোল্ডার সেট করছি
WORKDIR /usr/src/app

# ৩. package.json ফাইলগুলো আগে কপি করছি
COPY package*.json ./

# ৪. কন্টেইনারের ভেতরে ডিপেন্ডেন্সি ইনস্টল করছি
RUN npm install

# ۵. আমাদের লোকাল কম্পিউটারের বাকি সব কোড কন্টেইনারে কপি করছি
COPY . .

# ৬. অ্যাপটি ৩০০০ পোর্টে চলবে তা ডকারকে জানাচ্ছি
EXPOSE 3000

# ৭. কন্টেইনার চালু হলে অ্যাপ রান করার কমান্ড
CMD ["node", "server.js"]